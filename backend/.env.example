DB_URL=jdbc:mysql://localhost:3306/swifteats_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DRIVER=com.mysql.cj.jdbc.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000
RESET_PASSWORD_EXPIRATION_MS=900000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
TOKEN_CLEANUP_FIXED_DELAY_MS=3600000
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=900
RATE_LIMIT_FORGOT_PASSWORD_MAX_REQUESTS=3
RATE_LIMIT_REFRESH_WINDOW_SECONDS=300
RATE_LIMIT_REFRESH_MAX_REQUESTS=20
CORS_ALLOWED_ORIGINS=http://localhost:3000
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=no-reply@example.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
H2_CONSOLE_ENABLED=false
