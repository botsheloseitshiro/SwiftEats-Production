# ─────────────────────────────────────────────────────────────
# SwiftEats Environment Variables — Production Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# For local dev (H2 in-memory, no setup needed):
# DB_URL=jdbc:h2:mem:swifteats_db;MODE=MySQL;DB_CLOSE_DELAY=-1
# DB_USERNAME=sa
# DB_PASSWORD=
# DB_DRIVER=org.h2.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect

# For production (MySQL):
DB_URL=jdbc:mysql://YOUR_HOST:3306/swifteats?useSSL=true&serverTimezone=UTC
DB_USERNAME=swifteats_user
DB_PASSWORD=your_strong_db_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

# Docker Compose extra (root for init only):
DB_ROOT_PASSWORD=your_root_password_here

# ── JWT Security ───────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# MUST be at least 32 characters. Keep this secret!
JWT_SECRET=REPLACE_WITH_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# Token lifetimes in milliseconds
JWT_ACCESS_EXPIRATION=1800000       # 30 minutes
JWT_REFRESH_EXPIRATION=604800000    # 7 days

# ── Email (SMTP) ───────────────────────────────────────────────
# For development: leave blank to skip email sending
# For production: use Gmail, SendGrid, Mailgun, etc.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=no-reply@swifteats.local

# ── Password Reset ─────────────────────────────────────────────
FRONTEND_RESET_PASSWORD_URL=https://yourapp.com/reset-password
RESET_PASSWORD_EXPIRATION_MS=900000   # 15 minutes
RESET_PASSWORD_EXPOSE_LINK=false      # true for dev only!

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourapp.com

# ── Spring Profile ─────────────────────────────────────────────
# Use 'dev' locally (enables H2 console, debug logging, DataSeeder)
# Use 'prod' in production
SPRING_PROFILES_ACTIVE=prod

# Seed demo data on first production deployment only when you explicitly want it.
# Leave false for normal production runs. Set true to pre-populate restaurants, users, orders, reviews, and favorites.
SEEDER_ENABLED=false

# Optional: enable OpenAPI docs in production only if you explicitly want them public.
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=900
RATE_LIMIT_FORGOT_PASSWORD_MAX_REQUESTS=3
RATE_LIMIT_REFRESH_WINDOW_SECONDS=300
RATE_LIMIT_REFRESH_MAX_REQUESTS=20

# ── Token Cleanup ──────────────────────────────────────────────
TOKEN_CLEANUP_FIXED_DELAY_MS=3600000  # 1 hour

# ── H2 Console (DEV ONLY) ──────────────────────────────────────
H2_CONSOLE_ENABLED=false   # true in dev, ALWAYS false in prod
